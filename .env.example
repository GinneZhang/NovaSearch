# ==========================================
# NovaSearch Environment Variables Template
# ==========================================

# 1. LLM & Embedding API Keys
OPENAI_API_KEY=sk-placeholder_your_openai_api_key_here
ANTHROPIC_API_KEY=sk-placeholder_your_anthropic_api_key_here

# 2. PostgreSQL (with pgvector) Core Config
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_secure_password
POSTGRES_DB=novasearch
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# 3. Redis (Session & Context Tracking)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# 4. Neo4j (Knowledge Graph)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_secure_password

# 5. Application Settings
API_ENV=development
LOG_LEVEL=DEBUG
