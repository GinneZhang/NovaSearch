# ------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ------------------------------------------
# 5. Virtual Environments
# ------------------------------------------
venv/
.venv/
env/
.env_folder/
pip-log.txt
pip-delete-this-directory.txt

# ------------------------------------------
