data/
datasets/
local_db/
chroma_db/
qdrant_storage/
*.faiss
*.index
*.vec

# Relational & Graph DB Data
neo4j_data/
neo4j_logs/
postgres_data/
pg_data/
redis_data/
dump.rdb
*.sqlite3
*.db

# ------------------------------------------
